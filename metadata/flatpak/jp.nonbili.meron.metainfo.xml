<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>jp.nonbili.meron</id>

  <name>Meron</name>
  <summary>Modern mail and feed client</summary>

  <developer id="jp.nonbili">
    <name>Nonbili Inc.</name>
  </developer>

  <metadata_license>CC-BY-SA-4.0</metadata_license>
  <project_license>AGPL-3.0-or-later</project_license>

  <description>
    <ul>
      <li>Email over IMAP/SMTP, with threaded conversations and a rich-text composer</li>
      <li>RSS / Atom feeds alongside your mail</li>
      <li>OAuth sign-in (e.g. Gmail) plus password auth with mailbox autodiscovery</li>
      <li>Encrypted local storage (SQLite via SQLCipher), with credentials kept in the OS keyring</li>
      <li>Native notifications and system tray integration</li>
      <li>Kanban board and gallery views for organizing and viewing message attachments</li>
    </ul>
  </description>

  <keywords>
    <keyword>email</keyword>
    <keyword>mail</keyword>
    <keyword>rss</keyword>
    <keyword>feed</keyword>
    <keyword>imap</keyword>
    <keyword>kanban</keyword>
  </keywords>

