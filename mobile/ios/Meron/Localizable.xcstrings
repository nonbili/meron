    "settings.storage.clearHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حذف المرفقات والصور المؤقتة. سيتم الاحتفاظ برسائلك."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zwischengespeicherte Anhänge und Bilder löschen. Ihre E-Mails bleiben erhalten."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Διαγραφή αποθηκευμένων συνημμένων και εικόνων. Τα μηνύματά σας διατηρούνται."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete cached attachments and images. Your mail is kept."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminar imágenes y archivos adjuntos en caché. Se conservará su correo."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Kustuta vahemällu salvestatud manused ja pildid. Sinu e-kirjad säilitatakse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer les pièces jointes et les images en cache. Vos e-mails sont conservés."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Elimina gli allegati e le immagini memorizzati nella cache. Le tue email verranno conservate."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캐시된 첨부 파일과 이미지를 삭제합니다. 이메일은 유지됩니다."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dzēst kešatmiņā saglabātos pielikumus un attēlus. Jūsu e-pasts tiks saglabāts."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usuń zapisane w pamięci podręcznej załączniki i obrazy. Poczta zostanie zachowana."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminar anexos e imagens em cache. O seu correio é mantido."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Excluir anexos e imagens em cache. Seus e-mails são mantidos."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta bort cachade bilagor och bilder. Din e-post behålls."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Önbelleğe alınmış ekleri ve resimleri siler. E-postalarınız korunur."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xóa các tệp đính kèm và hình ảnh được lưu trong bộ nhớ đệm. Thư của bạn vẫn được giữ lại."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "删除缓存的附件和图片。您的邮件将被保留。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "刪除快取的附件和圖片。您的郵件將被保留。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "キャッシュされた添付ファイルと画像を削除します。メールは保持されます。"
          }
        }
      }
    },
