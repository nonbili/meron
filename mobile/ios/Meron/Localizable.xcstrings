    "empty.mailSetupText": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف حساب IMAP/SMTP تقليدي لمزامنة صندوق بريدك في سلسلة رسائل بأسلوب دردشة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie ein klassisches IMAP/SMTP-Konto hinzu, um Ihr Postfach in einen Nachrichten-Thread im Chat-Stil zu synchronisieren."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Προσθέστε έναν παραδοσιακό λογαριασμό IMAP/SMTP για να συγχρονίσετε το γραμματοκιβώτιό σας σε ένα νήμα μηνυμάτων τύπου chat."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a traditional IMAP/SMTP account to sync your mailbox into a chat-style message thread."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añada una cuenta IMAP/SMTP tradicional para sincronizar su buzón de correo en un hilo de mensajes al estilo de chat."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Lisa tavapärane IMAP/SMTP konto, et sünkroonida oma postkast jututoa stiilis sõnumivestluseks."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez un compte IMAP/SMTP traditionnel pour synchroniser votre boîte de réception dans un fil de messages de style chat."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi un account IMAP/SMTP tradizionale per sincronizzare la tua casella postale in un thread di messaggi in stile chat."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기존 IMAP/SMTP 계정을 추가하여 편지함을 채팅 스타일의 메시지 스레드로 동기화해 보세요."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pievienojiet tradicionālo IMAP/SMTP kontu, lai sinhronizētu savu pastkasti tērzēšanas stila ziņojumu pavedienā."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodaj tradycyjne konto IMAP/SMTP, aby zsynchronizować swoją skrzynkę pocztową w wątek wiadomości w stylu czatu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione uma conta IMAP/SMTP tradicional para sincronizar a sua caixa de correio num tópico de mensagens ao estilo de chat."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione uma conta IMAP/SMTP tradicional para sincronizar sua caixa de correio em uma conversa estilo chat."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lägg till ett vanligt IMAP/SMTP-konto för att synkronisera din brevlåda till en meddelandetråd i chat-stil."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Posta kutunuzu sohbet tarzı bir ileti dizisiyle senkronize etmek için geleneksel bir IMAP/SMTP hesabı ekleyin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Thêm một tài khoản IMAP/SMTP truyền thống để đồng bộ hộp thư của bạn thành một luồng tin nhắn kiểu trò chuyện."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加传统的 IMAP/SMTP 账户，将您的邮箱同步为 聊天风格的消息会话线索。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "新增傳統 IMAP/SMTP 帳戶以將您的信箱同步為 聊天風格的訊息對話串。"
