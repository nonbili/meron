    "feeds.urlHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الصق رابط خلاصة، أو عنوان موقع لاكتشاف خلاصته تلقائيًا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie eine Feed-URL oder eine Website-Adresse ein, um deren Feed automatisch zu erkennen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επικολλήστε ένα URL ροής ή μια διεύθυνση ιστότοπου για αυτόματο εντοπισμό της ροής του."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Paste a feed URL, or a site address to auto-discover its feed."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pegue la URL de un feed, o la dirección de un sitio para detectar automáticamente su feed."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Kleebi voo URL või saidi aadress, et selle voog automaatselt tuvastada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Collez l'URL d'un flux ou l'adresse d'un site pour découvrir automatiquement son flux."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Incolla l'URL di un feed o l'indirizzo di un sito per trovarne automaticamente il feed."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "피드 URL 또는 사이트 주소를 붙여넣어 피드를 자동 감지합니다."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ielīmējiet plūsmas URL vai vietnes adresi, lai automātiski atklātu tās plūsmu."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wklej URL kanału lub adres witryny, aby automatycznie wykryć jej kanał."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Cole o URL do feed ou o endereço de um site para descobrir automaticamente o seu feed."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Cole a URL do feed ou o endereço de um site para descobrir seu feed automaticamente."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Klistra in en flödes-URL, eller en webbplatsadress för att automatiskt hitta dess flöde."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir besleme URL'si veya beslemesini otomatik keşfetmek için bir site adresi yapıştırın."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Dán một URL nguồn tin hoặc một địa chỉ trang web để tự động phát hiện nguồn tin."
