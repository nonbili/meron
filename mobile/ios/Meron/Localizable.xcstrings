        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bunları yazdıkça otomatik olarak biçimlendirilirler"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhập các ký tự này và chúng sẽ tự động định dạng khi bạn viết"
          }
        },
        "zh-Hans": {
