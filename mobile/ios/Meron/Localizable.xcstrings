            "state": "translated",
            "value": "Stoppt die Prüfung auf neue Nachrichten; vorhandene bleiben lesbar."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Σταματά τον έλεγχο για νέα μηνύματα. Τα υπάρχοντα παραμένουν αναγνώσιμα."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Stops checking for new messages; existing ones stay readable."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Detiene la comprobación de nuevos mensajes; los existentes siguen siendo legibles."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Peatab uute sõnumite kontrollimise; olemasolevad jäävad loetavaks."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Arrête la recherche de nouveaux messages ; les messages existants restent lisibles."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Interrompe il controllo dei nuovi messaggi; quelli esistenti rimangono leggibili."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "새 메시지 확인을 중단합니다. 기존 메시지는 계속 읽을 수 있습니다."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Aptur jaunu ziņojumu pārbaudi; esošie joprojām ir lasāmi."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zatrzymuje sprawdzanie nowych wiadomości; istniejące wiadomości pozostają czytelne."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Para de verificar novas mensagens; as existentes continuam legíveis."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Para de verificar novas mensagens; as existentes continuam legíveis."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Stoppar hämtning av nya meddelanden; befintliga förblir läsbara."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Yeni mesajların kontrol edilmesini durdurur; mevcut mesajlar okunabilir kalır."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Dừng kiểm tra tin nhắn mới; các tin nhắn hiện có vẫn đọc được."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "停止检查新消息；现有消息仍可读取。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "停止檢查新訊息，現有訊息仍可閱讀。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "新しいメッセージの確認を停止します。既存のメッセージは引き続き閲覧可能です。"
          }
        }
      }
    },
