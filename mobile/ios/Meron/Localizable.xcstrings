    "theme.deleteMessage": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل تريد حذف السمة المخصصة \"{name}\"؟ لا يمكن التراجع عن هذا الإجراء."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das benutzerdefinierte Design „{name}“ löschen? Dies kann nicht rückgängig gemacht werden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Διαγραφή του προσαρμοσμένου θέματος \"{name}\"; Αυτή η ενέργεια δεν μπορεί να αναιρεθεί."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Delete the custom theme \"{name}\"? This cannot be undone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Eliminar el tema personalizado \"{name}\"? Esto no se puede deshacer."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Kas kustutada kohandatud kujundus \"{name}\"? Seda toimingut ei saa tagasi võtta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer le thème personnalisé « {name} » ? Cette action est irréversible."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminare il tema personalizzato \"{name}\"? Questa azione non può essere annullata."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사용자 지정 테마 \"{name}\"을(를) 삭제하시겠습니까? 이 작업은 되돌릴 수 없습니다."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vai dzēst pielāgoto motīvu \"{name}\"? Šo darbību nevar atsaukt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usunąć własny motyw „{name}”? Tego kroku nie można cofnąć."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Eliminar o tema personalizado \"{name}\"? Isto não pode ser anulado."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Excluir o tema personalizado \"{name}\"? Esta ação não pode ser desfeita."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ta bort det anpassade temat \"{name}\"? Detta kan inte ångras."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "\"{name}\" özel teması silinsin mi? Bu işlem geri alınamaz."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xóa giao diện tùy chỉnh \"{name}\"? Hành động này không thể hoàn tác."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "确定要删除自定义主题 \"{name}\" 吗？此操作无法撤销。"
