    "settings.account.muteNotificationsHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لا تزال الرسائل تصل وتتزامن؛ لن يظهر إشعار على سطح المكتب."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nachrichten kommen weiterhin an und werden synchronisiert; keine Desktop-Benachrichtigung."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Τα μηνύματα εξακολουθούν να φτάνουν και να συγχρονίζονται, χωρίς ειδοποίηση στην επιφάνεια εργασίας."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Messages still arrive and sync; no desktop notification."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los mensajes siguen llegando y sincronizándose; sin notificación de escritorio."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Sõnumid saabuvad ja sünkroonitakse ikka, kuid töölauateavitust ei näidata."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les messages arrivent et se synchronisent toujours ; pas de notification de bureau."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "I messaggi arrivano e si sincronizzano comunque; nessuna notifica sul desktop."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메시지는 계속 수신 및 동기화되지만 데스크톱 알림은 표시되지 않습니다."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ziņojumi joprojām pienāk un tiek sinhronizēti; nav darbvirsmas paziņojumu."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wiadomości nadal będą docierać i się synchronizować, ale bez powiadomień na pulpicie."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "As mensagens continuam a chegar e a sincronizar; sem notificações no ambiente de trabalho."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As mensagens continuam chegando e sincronizando; sem notificações na área de trabalho."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Meddelanden tas fortfarande emot och synkroniseras; ingen skrivbordsavisering."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mesajlar gelmeye ve senkronize edilmeye devam eder; masaüstü bildirimi gösterilmez."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tin nhắn vẫn được tải và đồng bộ; không hiển thị thông báo màn hình."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "消息仍会到达并进行同步；但不会有桌面通知。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "訊息仍會送達與同步，但不會顯示桌面通知。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メッセージは引き続き受信および同期されますが、デスクトップ通知は表示されません。"
          }
        }
      }
    },
