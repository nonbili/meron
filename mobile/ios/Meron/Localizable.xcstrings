    "accounts.oauth.configureGmail": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يرجى تهيئة MERON_GOOGLE_CLIENT_ID و MERON_GOOGLE_CLIENT_SECRET في بيئة الشل الخاصة بك قبل ربط Gmail."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitte konfigurieren Sie MERON_GOOGLE_CLIENT_ID and MERON_GOOGLE_CLIENT_SECRET in Ihrer Shell-Umgebung, bevor Sie Gmail verbinden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Παρακαλούμε ρυθμίστε τα MERON_GOOGLE_CLIENT_ID και MERON_GOOGLE_CLIENT_SECRET στο περιβάλλον του κελύφους σας (shell) πριν συνδέσετε το Gmail."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please configure MERON_GOOGLE_CLIENT_ID and MERON_GOOGLE_CLIENT_SECRET in your shell environment before connecting Gmail."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure MERON_GOOGLE_CLIENT_ID y MERON_GOOGLE_CLIENT_SECRET en su entorno de shell antes de conectar Gmail."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Palun seadista oma kesta keskkonnas MERON_GOOGLE_CLIENT_ID ja MERON_GOOGLE_CLIENT_SECRET enne Gmaili ühendamist."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Veuillez configurer MERON_GOOGLE_CLIENT_ID et MERON_GOOGLE_CLIENT_SECRET dans votre environnement de terminal avant de connecter Gmail."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Si prega di configurare MERON_GOOGLE_CLIENT_ID e MERON_GOOGLE_CLIENT_SECRET nel proprio ambiente di shell prima di connettere Gmail."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Gmail을 연결하기 전에 셸 환경에서 MERON_GOOGLE_CLIENT_ID 및 MERON_GOOGLE_CLIENT_SECRET을 구성해 주세요."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pirms Gmail pievienošanas, lūdzu, konfigurējiet MERON_GOOGLE_CLIENT_ID un MERON_GOOGLE_CLIENT_SECRET savā čaulas (shell) vidē."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przed połączeniem z Gmailem skonfiguruj MERON_GOOGLE_CLIENT_ID i MERON_GOOGLE_CLIENT_SECRET w swoim środowisku powłoki."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure MERON_GOOGLE_CLIENT_ID e MERON_GOOGLE_CLIENT_SECRET no seu ambiente de shell antes de associar o Gmail."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Configure MERON_GOOGLE_CLIENT_ID e MERON_GOOGLE_CLIENT_SECRET no seu ambiente de shell antes de conectar o Gmail."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Konfigurera MERON_GOOGLE_CLIENT_ID och MERON_GOOGLE_CLIENT_SECRET i din skalmiljö innan du ansluter Gmail."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lütfen Gmail'i bağlamadan önce kabuk ortamınızda MERON_GOOGLE_CLIENT_ID ve MERON_GOOGLE_CLIENT_SECRET değişkenlerini yapılandırın."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vui lòng cấu hình MERON_GOOGLE_CLIENT_ID và MERON_GOOGLE_CLIENT_SECRET trong môi trường shell của bạn trước khi kết nối Gmail."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请在连接 Gmail 之前，先在 Shell 环境中配置 MERON_GOOGLE_CLIENT_ID 和 MERON_GOOGLE_CLIENT_SECRET。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在連結 Gmail 之前，請先在您的命令列環境中設定 MERON_GOOGLE_CLIENT_ID 和 MERON_GOOGLE_CLIENT_SECRET。"
          }
        },
        "ja": {
