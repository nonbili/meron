    "settings.appearance.showSenderImagesHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يجلب صور المرسل من Gravatar، مع استخدام أيقونات المواقع كبديل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ruft Absenderbilder von Gravatar ab, mit Domain-Favicons als Ausweichlösung."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ανακτά εικόνες αποστολέα από το Gravatar, με εικονίδια ιστοτόπου (favicons) ως εναλλακτική."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fetches sender images from Gravatar, with domain favicons as fallback."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Obtiene imágenes de los remitentes de Gravatar, con favicons de dominio como alternativa."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Laadib saatja pildid Gravatarist, kasutades varulahendusena domeeni ikoone (favicon)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Récupère les photos d'expéditeurs depuis Gravatar, avec les favicons des domaines en secours."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Recupera le immagini dei mittenti da Gravatar, utilizzando le favicon del dominio come ripiego."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Gravatar에서 보내는 사람 이미지를 가져오며, 실패 시 도메인 파비콘을 폴백으로 사용합니다."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Iegūst sūtītāja attēlus no Gravatar, kā rezerves variantu izmantojot domēna favikonu."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Pobiera zdjęcia nadawców z Gravatara, a jako zapasowe używa ikon domen (favicon)."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Obtém imagens do remetente do Gravatar, com favicons do domínio como alternativa."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Busca imagens dos remetentes no Gravatar, usando favicons de domínio como alternativa."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Hämtar avsändarbilder från Gravatar, med domän-faviconer som reserv."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gönderen resimlerini Gravatar'dan çeker, domain favicon'larını yedek olarak kullanır."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tải ảnh người gửi từ Gravatar, sử dụng favicon của tên miền để dự phòng."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从 Gravatar 获取发件人头像，并以域名 favicon 作为备选。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自 Gravatar 取得寄件者圖片，並以網域的 Favicon 作為備用方案。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Gravatarから送信者の画像を取得します（フォールバックとしてドメインのファビコンを使用）。"
          }
        }
      }
    },
