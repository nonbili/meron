        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Saisissez-les et ils se formateront au fur et à mesure que vous écrivez"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Digitali e verranno formattati durante la scrittura"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "입력하면 입력하는 즉시 서식이 지정됩니다"
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ierakstiet tos, un tie tiks formatēti rakstīšanas laikā"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wpisz je, a zostaną sformatowane podczas pisania"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Escreva estes caracteres e o texto será formatado à medida que escreve"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Digite estes caracteres e eles serão formatados ao escrever"
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Skriv dessa så formateras de medan du skriver"
