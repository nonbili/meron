    "accounts.setup.feedAccountHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أنشئ الحساب الآن؛ يمكنك إضافة المزيد من الخلاصات في أي وقت باستخدام زر \"+\" الموجود أعلى قائمة الخلاصات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erstellen Sie das Konto jetzt; fügen Sie jederzeit weitere Feeds über das „+“ über der Feed-Liste hinzu."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δημιουργήστε τον λογαριασμό τώρα. Μπορείτε να προσθέσετε περισσότερες ροές ανά πάσα στιγμή με το \"+\" πάνω από τη λίστα ροών."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create the account now; add more feeds anytime with the \"+\" above the feed list."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cree la cuenta ahora; añada más feeds en cualquier momento con el \"+\" sobre la lista de feeds."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Loo konto nüüd; saad lisada vooge igal ajal voo loendi kohal oleva nupu \"+\" abil."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Créez le compte maintenant ; ajoutez d'autres flux à tout moment avec le « + » au-dessus de la liste des flux."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Crea l'account ora; aggiungi altri feed in qualsiasi momento con il \"+\" sopra l'elenco dei feed."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "지금 계정을 만드세요. 피드 목록 위의 \"+\"를 사용하여 언제든지 피드를 추가할 수 있습니다."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Izveidojiet kontu tagad; pievienojiet vairāk plūsmu jebkurā laikā, izmantojot \"+\" virs plūsmu saraksta."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Utwórz konto teraz; możesz dodać więcej kanałów w dowolnym momencie za pomocą „+” nad listą kanałów."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Crie a conta agora; adicione mais feeds a qualquer momento com o \"+\" acima da lista de feeds."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Crie a conta agora; adicione mais feeds a qualquer momento com o \"+\" acima da lista de feeds."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Skapa kontot nu; lägg till fler flöden när som helst med \"+\" ovanför flödeslistan."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hesabı şimdi oluşturun; besleme listesinin üzerindeki \"+\" simgesiyle istediğiniz zaman daha fazla besleme ekleyin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tạo tài khoản ngay bây giờ; thêm các nguồn tin khác bất kỳ lúc nào bằng nút \"+\" phía trên danh sách nguồn tin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "立即创建账户；随时使用订阅源列表上方的 \"+\" 添加更多订阅源。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "立即建立帳戶；隨時使用訂閱源清單上方的 \"+\" 新增更多訂閱源。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "今すぐアカウントを作成します。フィードリストの上にある「+」でいつでもフィードを追加できます。"
          }
        }
      }
    },
