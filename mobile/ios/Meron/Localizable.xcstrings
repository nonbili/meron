    "accounts.appPasswordHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "{provider} يتطلب كلمة مرور خاصة بالتطبيق - لن تعمل كلمة مرور حسابك العادية هنا. <action>قم بإنشاء واحدة لـ {provider}</action>، ثم الصقها أعلاه."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "{provider} erfordert ein App-spezifisches Passwort – Ihr normales Kontopasswort funktioniert hier nicht. <action>Generieren Sie eines für {provider}</action> und fügen Sie es oben ein."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Το {provider} απαιτεί έναν κωδικό πρόσβασης ειδικό για την εφαρμογή - ο κανονικός κωδικός πρόσβασης του λογαριασμού σας δεν θα λειτουργήσει εδώ. <action>Δημιουργήστε έναν για το {provider}</action> και, στη συνέχεια, επικολλήστε τον παραπάνω."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "{provider} requires an app-specific password - your normal account password won't work here. <action>Generate one for {provider}</action>, then paste it above."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "{provider} requiere una contraseña específica de la aplicación; su contraseña de cuenta normal no funcionará aquí. <action>Genere una para {provider}</action>, luego péguela arriba."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "{provider} nõuab rakendusepõhist parooli – sinu tavaline konto parool siin ei toimi. <action>Loo parool teenuse {provider} jaoks</action> ja kopeeri see ülalolevale väljale."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "{provider} requiert un mot de passe d'application spécifique - votre mot de passe de compte habituel ne fonctionnera pas ici. <action>Générez-en un pour {provider}</action>, puis collez-le ci-dessus."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "{provider} richiede una password specifica per l'applicazione - la tua normale password dell'account non funzionerà qui. <action>Generane una per {provider}</action>, quindi incollala sopra."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "{provider}은(는) 앱 전용 비밀번호가 필요합니다. 일반 계정 비밀번호는 여기에 작동하지 않습니다. <action>{provider}용 앱 비밀번호 생성</action> 후 위에 붙여넣으세요."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "{provider} nepieciešama lietotnei specifiska parole — jūsu parastā konta parole šeit nedarbosies. <action>Ģenerējiet to {provider}</action>, pēc tam ielīmējiet to augstāk."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "{provider} wymaga hasła dedykowanego do aplikacji - Twoje standardowe hasło do konta tutaj nie zadziała. <action>Wygeneruj je dla {provider}</action>, a następnie wklej powyżej."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O {provider} requer uma palavra-passe específica da aplicação - a palavra-passe normal da sua conta não funcionará aqui. <action>Gere uma para o {provider}</action> e cole-a acima."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O {provider} requer uma senha específica de aplicativo - sua senha normal de conta não funcionará aqui. <action>Gere uma para o {provider}</action> e cole-a acima."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "{provider} kräver ett appspecifikt lösenord - ditt vanliga kontolösenord fungerar inte här. <action>Skapa ett för {provider}</action> och klistra sedan in det ovan."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "{provider} uygulama şifresi gerektirir - normal hesap şifreniz burada çalışmaz. <action>{provider} için bir tane oluşturun</action> ve ardından yukarıya yapıştırın."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "{provider} yêu cầu mật khẩu ứng dụng chuyên biệt - mật khẩu tài khoản thông thường của bạn sẽ không hoạt động ở đây. <action>Tạo một mật khẩu ứng dụng cho {provider}</action>, sau đó dán vào phía trên."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "{provider} 需要应用专用密码 - 您普通的账户密码在此处无法使用。<action>为 {provider} 生成一个应用密码</action>，然后将其粘贴在上方。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "{provider} 需要應用程式專用密碼 - 您的常用帳戶密碼在此處無法使用。<action>為 {provider} 產生一個應用程式專用密碼</action>，然後貼在上方。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "{provider} はアプリ固有のパスワードを必要とします - 通常のアカウントパスワードはここでは使用できません。<action>{provider} のパスワードを生成</action>し、上に貼り付けてください。"
          }
        }
      }
    },
