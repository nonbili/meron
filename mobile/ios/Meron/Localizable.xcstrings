    "composer.toolbar.markdownHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اكتب هذه التنسيقات وسيتم تطبيقها أثناء الكتابة"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Geben Sie diese ein und sie werden beim Schreiben formatiert"
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πληκτρολογήστε αυτά και θα μορφοποιηθούν καθώς γράφετε"
