    "empty.noConversationSelectedText": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حدد سلسلة رسائل من قائمة الشريط الجانبي لعرض محتوياتها أو الرد أو إدارة المرفقات."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wählen Sie einen Nachrichten-Thread aus der Seitenleiste aus, um dessen Inhalt anzuzeigen, zu antworten oder Anhänge zu verwalten."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επιλέξτε ένα νήμα μηνυμάτων από τη λίστα της πλευρικής στήλης για να δείτε τα περιεχομένά του, να απαντήσετε ή να διαχειριστείτε συνημμένα."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Select a message thread from the thread list to view its contents, reply, or manage attachments."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Seleccione un hilo de mensajes de la lista lateral para ver su contenido, responder o gestionar archivos adjuntos."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Vali külgribalt sõnumilõim, et vaadata selle sisu, vastata või hallata manuseid."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sélectionnez un fil de discussion dans la liste latérale pour afficher son contenu, répondre ou gérer les pièces jointes."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Seleziona un thread di messaggi dall'elenco nella barra laterale per visualizzarne il contenuto, rispondere o gestire gli allegati."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사이드바 목록에서 메시지 스레드를 선택하여 내용을 보거나, 답장하거나, 첨부 파일을 관리하세요."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Sānjoslas sarakstā atlasiet ziņojumu pavedienu, lai skatītu tā saturu, atbildētu vai pārvaldītu pielikumus."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz wątek wiadomości z listy na pasku bocznym, aby wyświetlić jego zawartość, odpowiedzieć lub zarządzać załącznikami."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecione um tópico de mensagens na lista da barra lateral para ver o seu conteúdo, responder ou gerir anexos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Selecione uma conversa na lista da barra lateral para ver seu conteúdo, responder ou gerenciar anexos."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj en meddelandetråd från sidofältet för att visa dess innehåll, svara eller hantera bilagor."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "İçeriğini görüntülemek, yanıtlamak veya ekleri yönetmek için kenar çubuğu listesinden bir ileti dizisi seçin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chọn một luồng tin nhắn từ danh sách thanh bên để xem nội dung, trả lời hoặc quản lý tệp đính kèm."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从侧边栏列表中选择一个消息会话来查看其内容、回复或管理附件。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從側邊欄清單中選取訊息對話串以檢視其內容、回覆或管理附件。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サイドバーのリストからメッセージスレッドを選択して、内容を表示したり、返信したり、添付ファイルを管理したりします。"
          }
        }
      }
    },
