    "settings.storage.usageHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "مساحة القرص المستخدمة بواسطة المرفقات المؤقتة وقاعدة البيانات المحلية."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Speicherplatz, der von zwischengespeicherten Anhängen und der lokalen Datenbank belegt wird."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Χώρος στο δίσκο που χρησιμοποιείται από τα αποθηκευμένα συνημμένα και την τοπική βάση δεδομένων."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Disk space used by cached attachments and the local database."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Espacio en disco utilizado por los archivos adjuntos en caché y la base de datos local."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Vahemällu salvestatud manuste ja kohaliku andmebaasi kasutatav kettaruum."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Espace disque utilisé par les pièces jointes en cache et la base de données locale."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Spazio su disco utilizzato dagli allegati memorizzati nella cache e dal database locale."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "캐시된 첨부 파일 및 로컬 데이터베이스가 사용하는 디스크 공간입니다."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Diska vieta, ko izmanto kešatmiņā saglabātie pielikumi un vietējā datubāze."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Miejsce na dysku zajmowane przez buforowane załączniki i lokalną bazę danych."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Espaço em disco utilizado pelos anexos em cache e pela base de dados local."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Espaço em disco usado por anexos em cache e pelo banco de dados local."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Diskutrymme som används av cachade bilagor och den lokala databasen."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Önbelleğe alınmış ekler ve yerel veri tabanı tarafından kullanılan disk alanı."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không gian đĩa được sử dụng bởi các tệp đính kèm được lưu trong bộ nhớ cache và cơ sở dữ liệu cục bộ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "缓存附件和本地数据库占用的磁盘空间。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "快取附件和本機資料庫佔用的磁碟空間。"
