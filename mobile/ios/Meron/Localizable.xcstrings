    "settings.account.loadRemoteImagesHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "معطل افتراضيًا للبريد الإلكتروني لتجنب بكسلات التتبع."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Für E-Mails standardmäßig deaktiviert, um Tracking-Pixel zu vermeiden."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Απενεργοποιημένο από προεπιλογή για τα email για την αποφυγή pixel παρακολούθησης."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Off by default for email to avoid tracking pixels."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desactivado por defecto para el correo electrónico para evitar píxeles de seguimiento."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaikimisi e-kirjades keelatud, et vältida jälgimispiksleid."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Désactivé par défaut pour les e-mails afin d'éviter les pixels de suivi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Disattivato per impostazione predefinita per evitare pixel di tracciamento."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "추적 픽셀을 방지하기 위해 이메일의 경우 기본적으로 비활성화되어 있습니다."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pēc noklusējuma izslēgts e-pastam, lai izvairītos no izsekošanas pikseļiem."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Domyślnie wyłączone dla poczty e-mail w celu uniknięcia pikseli śledzących."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Desativado por predefinição para e-mails para evitar pixels de monitorização."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desativado por padrão para e-mails para evitar rastreamento por pixels."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Inaktiverat som standard för e-post för att undvika spårningspixlar."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Takip piksellerini önlemek için e-postalar için varsayılan olarak kapalıdır."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mặc định tắt đối với email để tránh các pixel theo dõi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "电子邮件默认关闭，以避免追踪像素。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "電子郵件預設關閉此功能，以避免追蹤像素。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トラッキングピクセルを防ぐため、メールではデフォルトでオフになっています。"
          }
        }
      }
    },
