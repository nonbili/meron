    "connectivity.syncFailed": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تعذر الاتصال بخادم البريد. سيتم إعادة المحاولة في المزامنة التالية..."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Mailserver konnte nicht erreicht werden. Versuch wird bei der nächsten Synchronisierung wiederholt..."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν ήταν δυνατή η σύνδεση με τον διακομιστή αλληλογραφίας. Επανάληψη στην επόμενη σύνδεση..."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't reach the mail server. Retrying on the next sync…"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No se pudo conectar al servidor de correo. Reintentando en la próxima sincronización..."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "E-posti serveriga ei saadud ühendust. Uus katse järgmisel sünkroonimisel..."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de contacter le serveur de messagerie. Nouvel essai lors de la prochaine synchronisation..."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossibile raggiungere il server di posta. Nuovo tentativo al prossimo rilevamento..."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "메일 서버에 연결할 수 없습니다. 다음 동기화 시 다시 시도합니다…"
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Neizdevās sasniegt pasta serveri. Tiks mēģināts vēlreiz nākamajā sinhronizācijā..."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie udało się połączyć z serwerem poczty. Ponowna próba przy następnej synchronizacji..."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível contactar o servidor de correio. A tentar novamente na próxima sincronização..."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não foi possível conectar ao servidor de e-mail. Tentando novamente na próxima sincronização..."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Kunde inte nå e-postservern. Försöker igen vid nästa synkronisering..."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "E-posta sunucusuna erişilemedi. Bir sonraki eşitlemede tekrar denenecek..."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không thể kết nối với máy chủ thư. Đang thử lại trong lần đồng bộ tiếp theo..."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法连接到邮件服务器。将在下次同步时重试…"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法連接至郵件伺服器。將於下次同步時重試…"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メールサーバーに接続できませんでした。次の同期時に再試行します…"
          }
        }
      }
    },
