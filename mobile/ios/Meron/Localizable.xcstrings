    "empty.noStarredItemsText": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ضع نجمة على الرسائل أو عناصر الخلاصة لجمعها هنا."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Versehen Sie Nachrichten oder Feed-Elemente mit einem Stern, um sie hier zu sammeln."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Προσθέστε αστέρι σε μηνύματα ή στοιχεία ροής για να τα συγκεντρώσετε εδώ."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Star messages or feed items to collect them here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Destaque mensajes o elementos de feeds para recopilarlos aquí."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Märgi sõnumid või voo üksused tärniga, et need siia koguda."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Marquez des messages ou des éléments de flux d'une étoile pour les rassembler ici."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Evidenzia messaggi o elementi dei feed per raccoglierli qui."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "여기에 수집하려면 메시지나 피드 항목에 별표를 표시하세요."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Atzīmējiet ziņojumus vai plūsmu vienumus ar zvaigznīti, lai tos apkopotu šeit."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Oznacz wiadomości lub elementy kanałów gwiazdką, aby je tutaj gromadzić."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Marque mensagens ou feeds com uma estrela para os colecionar aqui."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Marque mensagens ou itens de feed com estrela para coletá-los aqui."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Stjärnmärk meddelanden eller flödesobjekt för att samla dem här."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Mesajları veya besleme ögelerini burada toplamak için yıldız ekleyin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Gắn sao tin nhắn hoặc mục nguồn tin để thu thập chúng ở đây."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为邮件或订阅源项目加星标以在此处收集它们。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為訊息或訂閱源項目加星號以在此處收集。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "メッセージやフィードアイテムにスターを付けて、ここに集めます。"
          }
        }
      }
    },
