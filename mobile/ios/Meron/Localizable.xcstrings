    "settings.account.reconnectHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "قم باستعادة بيانات اعتماد سلسلة المفاتيح المفقودة لهذا الحساب."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Stellen Sie die fehlenden Schlüsselbund-Anmeldeinformationen für dieses Konto wieder her."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επαναφέρετε το διαπιστευτήριο κλειδιού που λείπει για αυτόν τον λογαριασμό."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Restore the missing keychain credential for this account."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Restaure la credencial de llavero que falta para esta cuenta."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Taastage selle konto jaoks puuduvad võtmehoidja mandaadid."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Restaurez les informations d'identification du trousseau manquantes pour ce compte."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Ripristina le credenziali del portachiavi mancanti per questo account."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 계정에 대해 누락된 키체인 자격 증명을 복원합니다."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Atjaunojiet šim kontam trūkstošos atslēgu piekariņa akreditācijas datus."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Przywróć brakujące dane uwierzytelniające pęku kluczy dla tego konta."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Restaure a credencial de chaveiro ausente desta conta."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Restaure a credencial de chaveiro ausente desta conta."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Återställ den saknade nyckelringens autentiseringsuppgifter för detta konto."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu hesap için eksik anahtarlık kimlik bilgilerini geri yükleyin."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Khôi phục thông tin xác thực móc khóa bị thiếu cho tài khoản này."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "恢复此帐户丢失的钥匙串凭据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "恢復此帳戶遺失的鑰匙串憑證。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアカウントの不足しているキーチェーン資格情報を復元します。"
          }
        }
      }
    },
