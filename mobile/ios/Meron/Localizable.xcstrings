    "settings.account.removeAccountText": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هل تريد إزالة %1$s؟ سيتم حذف البريد المخزن مؤقتًا لهذا الحساب من هذا الجهاز."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$s entfernen? Zwischengespeicherte E-Mails für dieses Konto werden von diesem Gerät gelöscht."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Κατάργηση %1$s; Η αποθηκευμένη αλληλογραφία για αυτόν τον λογαριασμό θα διαγραφεί από αυτήν τη συσκευή."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Remove %1$s? Cached mail for this account will be deleted from this device."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "¿Quitar %1$s? El correo almacenado en caché de esta cuenta se eliminará de este dispositivo."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Kas eemaldada %1$s? Selle konto vahemällu salvestatud kirjad kustutatakse sellest seadmest."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Supprimer %1$s ? Le courrier mis en cache pour ce compte sera supprimé de cet appareil."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Rimuovere %1$s? La posta memorizzata nella cache per questo account verrà eliminata da questo dispositivo."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%1$s을(를) 제거하시겠습니까? 이 계정의 캐시된 메일이 이 기기에서 삭제됩니다."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Vai noņemt %1$s? Šī konta kešatmiņā saglabātais pasts tiks dzēsts no šīs ierīces."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Usunąć %1$s? Poczta buforowana dla tego konta zostanie usunięta z tego urządzenia."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Remover %1$s? Os e-mails armazenados em cache desta conta serão excluídos deste dispositivo."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Remover %1$s? Os e-mails armazenados em cache desta conta serão excluídos deste dispositivo."
