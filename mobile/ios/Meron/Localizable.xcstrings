    "empty.noColumnsText": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أضف عمود مجلد أو تسمية إلى هذه اللوحة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Fügen Sie diesem Board eine Ordner- oder Label-Spalte hinzu."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Προσθέστε μια στήλη φακέλου ή ετικέτας σε αυτόν τον πίνακα."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a folder or label column to this board."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añada una columna de carpeta o etiqueta a este tablero."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Lisa sellele stendile kausta- või sildiveerg."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez une colonne de dossier ou d'étiquette à ce tableau."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi una colonna cartella o etichetta a questa bacheca."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 보드에 폴더나 레이블 열을 추가하세요."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Pievienojiet šai tāfelei mapes vai etiķetes kolonnu."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodaj kolumnę folderu lub etykiety do tej tablicy."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione uma coluna de pasta ou etiqueta a este quadro."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione uma coluna de pasta ou marcador a este quadro."
          }
        },
        "sv": {
