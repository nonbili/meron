    "settings.appearance.showSenderImagesHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يجلب صور المرسل من Gravatar، مع استخدام أيقونات المواقع كبديل."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ruft Absenderbilder von Gravatar ab, mit Domain-Favicons als Ausweichlösung."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ανακτά εικόνες αποστολέα από το Gravatar, με εικονίδια ιστοτόπου (favicons) ως εναλλακτική."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Fetches sender images from Gravatar, with domain favicons as fallback."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Obtiene imágenes de los remitentes de Gravatar, con favicons de dominio como alternativa."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Laadib saatja pildid Gravatarist, kasutades varulahendusena domeeni ikoone (favicon)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Récupère les photos d'expéditeurs depuis Gravatar, avec les favicons des domaines en secours."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Recupera le immagini dei mittenti da Gravatar, utilizzando le favicon del dominio come ripiego."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Gravatar에서 보내는 사람 이미지를 가져오며, 실패 시 도메인 파비콘을 폴백으로 사용합니다."
