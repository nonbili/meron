    "settings.account.aliasesHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عناوين إضافية يمكنك الإرسال منها. الردود على البريد المستلم على اسم مستعار تكون افتراضيًا من ذلك العنوان."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Zusätzliche Adressen, von denen aus Sie senden können. Antworten auf E-Mails, die an ein Alias empfangen wurden, verwenden standardmäßig diese Adresse."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Πρόσθετες διευθύνσεις από τις οποίες μπορείτε να στείλετε. Οι απαντήσεις σε μηνύματα που λαμβάνονται σε ένα ψευδώνυμο αποστέλλονται από αυτήν τη διεύθυνση από προεπιλογή."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extra addresses you can send from. Replies to mail received on an alias default to that address."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Direcciones adicionales desde las que puede enviar. Las respuestas al correo recibido en un alias se envían por defecto a esa dirección."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Täiendavad aadressid, millelt saad saata. Aliasele saabunud kirjale vastates kasutatakse vaikimisi seda aadressi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Adresses supplémentaires avec lesquelles vous pouvez envoyer des messages. Les réponses aux messages reçus sur un alias sont envoyées par défaut depuis cette adresse."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Indirizzi aggiuntivi da cui puoi inviare messaggi. Le risposte ai messaggi ricevuti su un alias utilizzano quell'indirizzo per impostazione predefinita."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "보낼 수 있는 추가 이메일 주소입니다. 별칭으로 수신한 메일에 대한 답장은 기본적으로 해당 주소로 설정됩니다."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Papildu adreses, no kurām varat sūtīt. Atbildes uz e-pastiem, kas saņemti uz aizstājvārdu, pēc noklusējuma tiek sūtītas no šīs adreses."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Dodatkowe adresy, z których możesz wysyłać wiadomości. Odpowiedzi na pocztę otrzymaną na dany alias są domyślnie wysyłane z tego adresu."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Endereços adicionais a partir dos quais pode enviar. As respostas a e-mails recebidos num alias usam esse endereço por predefinição."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Endereços extras dos quais você pode enviar. Respostas a e-mails recebidos em um alias usam esse endereço por padrão."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Extra adresser du kan skicka från. Svar på e-post som tagits emot på ett alias skickas från den adressen som standard."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gönderebileceğiniz ekstra adresler. Bir takma ada gelen postaların yanıtları varsayılan olarak o adrese gider."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Các địa chỉ bổ sung mà bạn có thể dùng để gửi thư. Việc trả lời thư được gửi tới một bí danh sẽ mặc định dùng địa chỉ bí danh đó."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您可以使用其他别名地址发送邮件。收到发往别名的邮件后回复时，默认会使用该别名地址。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您可以用來傳送郵件的其他地址。回覆在別名收到的郵件時，預設會使用該地址。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "送信元として使用できる追加のアドレス。エイリアスで受信したメールへの返信は、デフォルトでそのアドレスになります。"
          }
        }
      }
    },
