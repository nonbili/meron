    "mobile.accounts.oauthClientHint": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "استخدم معرفات عميل Gmail/Outlook للهواتف المحمولة المسجلة ومعايير URI لإعادة التوجيه الدقيقة."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verwenden Sie registrierte mobile Gmail/Outlook-Client-IDs und genaue Weiterleitungs-URIs."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Χρησιμοποιήστε καταχωρημένα αναγνωριστικά πελατών Gmail/Outlook για κινητά και ακριβή URI ανακατεύθυνσης."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use registered Gmail/Outlook mobile client IDs and exact redirect URIs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilice ID de clientes móviles de Gmail/Outlook registrados y URI de redireccionamiento exactos."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Kasutage registreeritud Gmaili/Outlooki mobiilikliendi ID-sid ja täpseid ümbersuunamise URI-sid."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilisez les identifiants de client mobile Gmail/Outlook enregistrés et les URI de redirection exacts."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Utilizza gli ID client mobile Gmail/Outlook registrati e gli URI di reindirizzamento esatti."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "등록된 Gmail/Outlook 모바일 클라이언트 ID와 정확한 리디렉션 URI를 사용하세요."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Izmantojiet reģistrētos Gmail/Outlook mobilo klientu ID un precīzus novirzīšanas URI."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Używaj zarejestrowanych identyfikatorów klientów mobilnych Gmail/Outlook i dokładnych identyfikatorów URI przekierowań."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Use IDs de clientes móveis registrados do Gmail/Outlook e URIs de redirecionamento exatos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Use IDs de clientes móveis registrados do Gmail/Outlook e URIs de redirecionamento exatos."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Använd registrerade Gmail/Outlook mobilklient-ID och exakta omdirigerings-URI:er."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kayıtlı Gmail/Outlook mobil istemci kimliklerini ve tam yönlendirme URI'lerini kullanın."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Sử dụng ID khách hàng di động Gmail/Outlook đã đăng ký và URI chuyển hướng chính xác."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "使用注册的 Gmail/Outlook 移动客户端 ID 和精确的重定向 URI。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "使用註冊的 Gmail/Outlook 行動用戶端 ID 和精確的重定向 URI。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "登録された Gmail/Outlook モバイル クライアント ID と正確なリダイレクト URI を使用します。"
          }
        }
      }
    },
