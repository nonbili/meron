# fastlane runtime artifacts
report.xml
Preview.html
README.md
*.html

# intermediate captures + frameit config/assets; only the framed screenshots
# under metadata/ are committed
screenshots/

# The shared changelog source is metadata/android/en-US/changelogs/<versionCode>.txt
# and IS committed (Google Play and F-Droid read it directly). Only the derived
# artifacts are ignored:
#  - default.txt (placeholder fallback)
#  - iOS release_notes.txt (copied from the versionCode changelog at upload)
metadata/android/en-US/changelogs/default.txt
metadata/ios/en-US/release_notes.txt
