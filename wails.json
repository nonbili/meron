{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "meron",
  "outputfilename": "meron",
  "frontend:install": "bun install",
  "frontend:build": "bun run build",
  "frontend:dev:watcher": "bun run dev -- --host 127.0.0.1 --port 5178 --strictPort",
