<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow Go runtime to allocate writable-executable memory -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Allow JIT compilation (needed for some JS/Webviews) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Allow outbound network connections -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Allow inbound network connections (if webview needs to talk to local sidecar RPC) -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- Disable library validation to allow WebKit to load dynamically -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
